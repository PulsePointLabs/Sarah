# PulsePoint standalone local backend
PORT=8787
DATA_DIR=./data
DATABASE_PATH=./data/pulsepoint.sqlite
UPLOAD_DIR=./data/uploads
TTS_RENDER_DIR=./data/tts-render-work

# Match the Base44-era Session Analysis model family by default.
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_MS=600000
# Optional local-only capture for controlled companion analysis comparison runs.
# Writes prompts/config/responses to data/debug/ai-forensics; do not leave enabled for routine use.
# AI_FORENSICS=true
# Optional admin reporting key for Settings & Status Claude cost reports
# ANTHROPIC_ADMIN_API_KEY=your_anthropic_admin_key_here

# Existing TTS/STT features
OPENAI_API_KEY=your_openai_key_here
# Optional admin reporting key for Settings & Status OpenAI API cost reports
# OPENAI_ADMIN_API_KEY=your_openai_admin_key_here

# Optional TTS tuning. Defaults intentionally mirror the original Base44-era voice path.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_FORMAT=aac
OPENAI_TTS_MAX_CHARS=4000
OPENAI_TTS_TIMEOUT_MS=30000
OPENAI_TTS_BACKEND_ATTEMPTS=3
OPENAI_TTS_SPEED=1.0
VITE_TTS_SPEED=1.0

# Local-only visual evidence extraction with the Python Qwen2.5-VL service.
# Frames are sent only to localhost. There is no mock mode and no cloud fallback.
LOCAL_VISION_ENABLED=true
LOCAL_VISION_ENGINE=local_qwen25vl
LOCAL_VISION_URL=http://127.0.0.1:8765
LOCAL_VISION_TIMEOUT_MS=180000
LOCAL_VISION_MAX_FRAMES=8
LOCAL_VISION_CONTINUOUS_MAX_SCAN_FRAMES=600

# Local Sarah text synthesis (private/local; no cloud fallback)
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=qwen2.5:14b
LOCAL_LLM_TIMEOUT_MS=300000

# Optional live capture sources. PulsePoint starts the HR relay inside the local API by default.
HR_CAPTURE_RELAY_ENABLED=true
HR_CAPTURE_RELAY_PORT=8765
HR_CAPTURE_WS_URL=ws://127.0.0.1:8765
# Store generated HR CSVs in ignored local app data by default.
HR_RECORDINGS_DIR=./data/heart-rate-recordings
# OBS websocket settings used by the embedded HR relay and capture helpers.
OBS_WS_URL=ws://127.0.0.1:4455
# OBS_PASSWORD=
# Defaults preserve the sibling HeartRate/EMG folder layout.
# HR_RECORDINGS_DIR=C:/path/to/HeartRate/recordings
# EMG_TEXT_DIR=C:/path/to/EMG
# EMG_SESSIONS_DIR=C:/path/to/EMG/emg_sessions
# Repo-local helper output alternatives:
# HR_RECORDINGS_DIR=./tools/capture/heart-rate/recordings
# EMG_TEXT_DIR=./tools/capture/emg
# EMG_SESSIONS_DIR=./tools/capture/emg/emg_sessions
EMG_POLL_MS=250
# Optional repo-local EMG helper overrides.
# EMG_SERIAL_PORT=COM5
# EMG_SERIAL_BAUD=115200
# EMG_OBS_ENABLED=true
# OBS_HOST=127.0.0.1
# OBS_PORT=4455

# Optional local queue tuning
BACKGROUND_JOB_CONCURRENCY=1
